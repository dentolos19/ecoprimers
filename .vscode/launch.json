{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "App",
      "request": "launch",
      "type": "debugpy",
      "module": "flask",
      "args": ["run"],
      "env": {
        "FLASK_APP": "src/main.py",
        "FLASK_DEBUG": "1"
      },
      "jinja": true,
      "autoStartBrowser": true
    },
    {
      "name": "App (Docker)",
      "request": "launch",
      "type": "docker",
      "preLaunchTask": "docker-run",
      "python": {
        "projectType": "flask",
        "pathMappings": [
          {
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/app"
          }
        ]
      }
    }
  ]
}
