{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "App",
      "request": "launch",
      "type": "debugpy",
      "cwd": "${workspaceFolder}/src/app",
      "python": "${workspaceFolder}/src/app/.venv/bin/python",
      "module": "flask",
      "args": ["run", "--port", "3000"],
      "env": {
        "FLASK_APP": "main.py",
        "FLASK_DEBUG": "1"
      },
      "jinja": true,
      "autoStartBrowser": true
    }
  ]
}
